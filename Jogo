<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Educação Digital PRO+</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f172a;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }
        .container {
            background: #1e293b;
            padding: 25px;
            border-radius: 16px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            text-align: center;
        }
        button {
            width: 100%;
            margin: 8px 0;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #3b82f6;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover { background: #2563eb; }
        button:disabled { background: #475569; cursor: not-allowed; }
        #next { background: #22c55e; margin-top: 15px; }
        #next:hover { background: #16a34a; }
        .top {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            margin-bottom: 20px;
            color: #94a3b8;
        }
        h2 { font-size: 1.4rem; margin-bottom: 20px; }
    </style>
</head>
<body>

<div class="container" id="quiz-container">
    <div class="top">
        <span id="progress"></span>
        <span id="score"></span>
        <span id="timer"></span>
    </div>
    <h2 id="question">Carregando...</h2>
    <div id="answers"></div>
    <button id="next" style="display:none;">Próxima Pergunta</button>
</div>

<script>
const questions = [
    {q:"O que é educação digital?",a:["Uso responsável",true,"Jogos",false,"Evitar internet",false,"Postar tudo",false]},
    {q:"O que é phishing?",a:["Golpe online",true,"Jogo",false,"App",false,"Rede",false]},
    {q:"O que é malware?",a:["Software malicioso",true,"App",false,"Rede",false,"Jogo",false]},
    {q:"O que são fake news?",a:["Informações falsas",true,"Verdadeiras",false,"Jogos",false,"Apps",false]},
    {q:"Senha segura deve ser:",a:["Complexa",true,"123456",false,"abc",false,"curta",false]},
    {q:"O que é 2FA?",a:["Segurança extra",true,"Vírus",false,"Erro",false,"Rede",false]},
    {q:"HTTPS significa:",a:["Conexão segura",true,"Site lento",false,"Erro",false,"Download",false]},
    {q:"Wi-Fi público pode:",a:["Expor dados",true,"Ajudar",false,"Nada",false,"Melhorar",false]},
    {q:"Backup é:",a:["Cópia de dados",true,"Apagar",false,"Editar",false,"Enviar",false]},
    {q:"Antivírus serve para:",a:["Proteger",true,"Jogar",false,"Postar",false,"Editar",false]}
    // ... Adicione as outras perguntas aqui seguindo o mesmo padrão
];

function shuffle(array){
    for(let i=array.length-1;i>0;i--){
        let j=Math.floor(Math.random()*(i+1));
        [array[i],array[j]]=[array[j],array[i]];
    }
    return array;
}

let questionBank = shuffle(questions.map(q=>({
    question:q.q,
    answers: shuffle([
        {text:q.a[0],correct:q.a[1]},
        {text:q.a[2],correct:q.a[3]},
        {text:q.a[4],correct:q.a[5]},
        {text:q.a[6],correct:q.a[7]}
    ])
})));

let index=0, score=0, timer, timeLeft=10;

const qEl=document.getElementById("question");
const aEl=document.getElementById("answers");
const nextBtn=document.getElementById("next");
const progress=document.getElementById("progress");
const scoreEl=document.getElementById("score");
const timerEl=document.getElementById("timer");

function startTimer(){
    clearInterval(timer);
    timeLeft=10;
    timerEl.innerText="⏱️ "+timeLeft+"s";
    timer=setInterval(()=>{
        timeLeft--;
        timerEl.innerText="⏱️ "+timeLeft+"s";
        if(timeLeft<=0){
            clearInterval(timer);
            disableButtons();
            nextBtn.style.display="block";
        }
    },1000);
}

function disableButtons() {
    const buttons = aEl.querySelectorAll("button");
    buttons.forEach(b => b.disabled = true);
}

function loadQuestion(){
    nextBtn.style.display="none";
    aEl.innerHTML="";

    if(index >= questionBank.length){
        showFinal();
        return;
    }

    let q = questionBank[index];
    qEl.innerText = q.question;
    progress.innerText = `Questão: ${index+1}/${questionBank.length}`;
    scoreEl.innerText = `Pontos: ${score}`;

    startTimer();

    q.answers.forEach(a => {
        let btn = document.createElement("button");
        btn.innerText = a.text;
        btn.onclick = () => {
            clearInterval(timer);
            if(a.correct) {
                score++;
                btn.style.background = "#22c55e";
            } else {
                btn.style.background = "#ef4444";
            }
            disableButtons();
            scoreEl.innerText = `Pontos: ${score}`;
            nextBtn.style.display = "block";
        };
        aEl.appendChild(btn);
    });
}

nextBtn.onclick=()=>{index++; loadQuestion()};

function showFinal(){
    clearInterval(timer);
    qEl.innerText = `Quiz Concluído!`;
    timerEl.innerText = "";
    aEl.innerHTML = `<p style="font-size:1.2rem">Sua pontuação final foi: <strong>${score}</strong> de ${questionBank.length}</p>`;
    aEl.innerHTML += `<button onclick="location.reload()">Reiniciar Quiz</button>`;
    saveRanking(score);
}

function saveRanking(score){
    let ranking=JSON.parse(localStorage.getItem("ranking")||"[]");
    ranking.push({date: new Date().toLocaleDateString(), points: score});
    ranking.sort((a,b)=>b.points-a.points);
    localStorage.setItem("ranking",JSON.stringify(ranking.slice(0,5))); // Salva top 5
}

loadQuestion();
</script>
</body>
</html>
